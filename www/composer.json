{
    "name": "alessandroisdev/cronjob",
    "description": "Trabalhando com filas de maneira simplificada",
    "autoload": {
        "psr-4": {
            "AlessandroIsDev\\CronJob\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlessandroIsDev\\CronJob\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Alessandro P Souza"
        }
    ],
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit",
        "worker": "php bin/worker.php"
    }
}
